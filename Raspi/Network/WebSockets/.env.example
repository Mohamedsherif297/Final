# ============================================================================
# Raspberry Pi Surveillance System - Environment Configuration
# ============================================================================
# Copy this file to .env and customize for your setup
# Load with: set -a; source .env; set +a

# ── Ngrok Tunneling (WAN Access) ────────────────────────────────────────────
# Enable Ngrok for remote internet access (no port forwarding needed)
NGROK_ENABLED=true

# Your Ngrok auth token (REQUIRED)
# Get from: https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTH_TOKEN=your_token_here

# Ngrok region (choose closest to your clients for best latency)
# Options: us, eu, ap, au, sa, jp, in
NGROK_REGION=us

# Enable/disable specific tunnels
NGROK_WEBSOCKET_ENABLED=true
NGROK_MQTT_ENABLED=true

# Ports to tunnel (should match your service ports below)
NGROK_WS_PORT=8765
NGROK_MQTT_PORT=1883

# ── WebSocket Server ────────────────────────────────────────────────────────
# Bind address (0.0.0.0 = all interfaces, 127.0.0.1 = localhost only)
WS_HOST=0.0.0.0

# WebSocket port
WS_PORT=8765

# WebSocket keep-alive settings (seconds)
WS_PING_INTERVAL=20
WS_PING_TIMEOUT=10

# Maximum message size (bytes)
WS_MAX_MESSAGE_SIZE=2097152

# Per-client queue depth (lower = less latency)
WS_CLIENT_QUEUE_MAX=2

# Statistics logging interval (seconds)
WS_STATS_INTERVAL=10.0

# ── MQTT Broker ─────────────────────────────────────────────────────────────
# MQTT broker hostname/IP (localhost if running Mosquitto on Pi)
MQTT_BROKER=localhost

# MQTT port (1883 = plain, 8883 = TLS)
MQTT_PORT=1883

# MQTT keep-alive interval (seconds)
MQTT_KEEPALIVE=60

# MQTT client ID
MQTT_CLIENT_ID=ws-bridge

# ── MQTT Topics ─────────────────────────────────────────────────────────────
MQTT_TOPIC_STATUS=dev/status
MQTT_TOPIC_MOTOR=dev/motor

# ── Video Capture ───────────────────────────────────────────────────────────
# Camera device index (0 = /dev/video0)
VIDEO_CAMERA_INDEX=0

# Capture resolution (640x480 recommended for Pi)
VIDEO_CAPTURE_WIDTH=640
VIDEO_CAPTURE_HEIGHT=480

# Target frame rate (15-20 recommended for Pi)
VIDEO_TARGET_FPS=20

# JPEG quality (60-70 recommended, lower = smaller files)
VIDEO_JPEG_QUALITY=65

# Video statistics interval (seconds)
VIDEO_STATS_INTERVAL=10.0

# ── Audio Capture ───────────────────────────────────────────────────────────
# Sample rate (16000 Hz standard for voice)
AUDIO_SAMPLE_RATE=16000

# Channels (1 = mono, 2 = stereo)
AUDIO_CHANNELS=1

# Sample width (2 = 16-bit)
AUDIO_SAMPLE_WIDTH=2

# Samples per chunk (1024 = ~64ms latency @ 16kHz)
AUDIO_CHUNK_SAMPLES=1024

# Audio device index (leave empty for default microphone)
# AUDIO_DEVICE_INDEX=0

# Audio queue depth
AUDIO_QUEUE_MAX=4

# Audio queue timeout (seconds)
AUDIO_QUEUE_TIMEOUT=0.05

# ── Logging ─────────────────────────────────────────────────────────────────
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
